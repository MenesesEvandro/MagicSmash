{
	"name": "magic-smash",
	"description": "Offline keyboard playground for toddlers — press any key, something delightful happens. No ads, no tracking, no internet needed.",
	"private": true,
	"license": "MIT",
	"type": "module",
	"scripts": {
		"build": "npm run check && node scripts/build.mjs",
		"test": "npm run build && node --test",
		"test:e2e": "npm run build && playwright test",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.4",
		"@playwright/test": "^1.61.1",
		"jsdom": "^29.1.1"
	}
}
